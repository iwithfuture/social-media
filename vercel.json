{
  "version": 2,
  "builds": [
    {
      "src": "api/[...path].mjs",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].mjs"
    },
    {
      "src": "/(.*\\.(?:html|js|css|json|png|jpg|jpeg|svg|webp|ico))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
